@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject SmartHelpdesk.Client.Services.AuthService AuthService

<div class="admin-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    <path d="M12 8v4"></path>
                    <path d="M12 16h.01"></path>
                </svg>
                <div class="logo-text">
                    <span class="brand-name">Smart Helpdesk</span>
                    <span class="brand-role">Admin Panel</span>
                </div>
            </div>
        </div>
        
        <div class="nav-section">
            <span class="nav-section-title">TỔNG QUAN</span>
            <nav class="sidebar-nav">
                <a href="/admin" class="nav-item @(IsActive("/admin", true) ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                    <span>Dashboard</span>
                </a>
                <a href="/admin/analytics" class="nav-item @(IsActive("/admin/analytics") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="20" x2="18" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                    <span>Thống kê</span>
                </a>
            </nav>
        </div>

        <div class="nav-section">
            <span class="nav-section-title">QUẢN LÝ</span>
            <nav class="sidebar-nav">
                <a href="/admin/categories" class="nav-item @(IsActive("/admin/categories") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                    <span>Loại sản phẩm</span>
                </a>
                <a href="/admin/products" class="nav-item @(IsActive("/admin/products") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                        <line x1="12" y1="22.08" x2="12" y2="12"></line>
                    </svg>
                    <span>Sản phẩm</span>
                </a>
                <a href="/admin/users" class="nav-item @(IsActive("/admin/users") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                    <span>Người dùng</span>
                </a>
                <a href="/admin/tickets" class="nav-item @(IsActive("/admin/tickets") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <span>Yêu cầu hỗ trợ</span>
                </a>
            </nav>
        </div>

        <div class="nav-section">
            <span class="nav-section-title">CẤU HÌNH</span>
            <nav class="sidebar-nav">
                <a href="/admin/settings" class="nav-item @(IsActive("/admin/settings") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    <span>Cài đặt hệ thống</span>
                </a>
            </nav>
        </div>
        
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="avatar admin-avatar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                </div>
                <div class="user-details">
                    <span class="user-name">@userName</span>
                    <span class="user-role">Quản trị viên</span>
                </div>
            </div>
            <button class="logout-btn" @onclick="Logout" title="Đăng xuất">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
            </button>
        </div>
    </aside>
    
    <!-- Main Content -->
    <main class="main-content">
        <header class="top-header">
            <div class="header-left">
                <button class="mobile-menu-btn" @onclick="ToggleMobileMenu">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <div class="breadcrumb">
                    <span class="breadcrumb-item">Admin</span>
                    <span class="breadcrumb-separator">/</span>
                    <span class="breadcrumb-item active">@GetCurrentPageName()</span>
                </div>
            </div>
            <div class="header-right">
                <div class="header-datetime">
                    <span class="date">@currentDateTime.ToString("dd/MM/yyyy")</span>
                    <span class="time">@currentDateTime.ToString("HH:mm")</span>
                </div>
            </div>
        </header>
        
        <div class="content-wrapper">
            @Body
        </div>
    </main>
</div>

@code {
    private string userName = "Admin";
    private bool isMobileMenuOpen = false;
    private DateTime currentDateTime = DateTime.Now;
    private System.Threading.Timer? clockTimer;

    protected override void OnInitialized()
    {
        // Cập nhật đồng hồ mỗi giây
        clockTimer = new System.Threading.Timer(async _ =>
        {
            currentDateTime = DateTime.Now;
            await InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Kiểm tra authentication
            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            if (!isAuthenticated)
            {
                Navigation.NavigateTo("/auth", forceLoad: true);
                return;
            }

            // Lấy tên user
            var name = await AuthService.GetUserNameAsync();
            if (!string.IsNullOrEmpty(name))
            {
                userName = name;
                StateHasChanged();
            }
        }
    }

    private bool IsActive(string path, bool exact = false)
    {
        var currentPath = Navigation.Uri.Replace(Navigation.BaseUri, "/");
        if (exact)
        {
            return currentPath == path || currentPath == path + "/";
        }
        return currentPath.StartsWith(path);
    }

    private string GetCurrentPageName()
    {
        var currentPath = Navigation.Uri.Replace(Navigation.BaseUri, "/");
        return currentPath switch
        {
            "/admin" or "/admin/" => "Dashboard",
            var p when p.StartsWith("/admin/analytics") => "Thống kê",
            var p when p.StartsWith("/admin/products") => "Quản lý sản phẩm",
            var p when p.StartsWith("/admin/users") => "Quản lý người dùng",
            var p when p.StartsWith("/admin/tickets") => "Yêu cầu hỗ trợ",
            var p when p.StartsWith("/admin/settings") => "Cài đặt",
            _ => "Dashboard"
        };
    }

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
    }

    private async Task Logout()
    {
        await AuthService.RemoveTokenAsync();
        Navigation.NavigateTo("/auth", forceLoad: true);
    }

    public void Dispose()
    {
        clockTimer?.Dispose();
    }
}
